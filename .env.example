# Never commit the real bot token.
TELEGRAM_BOT_TOKEN=replace-in-server-secret-storage
# Comma-separated numeric Telegram user IDs. Leave empty for the first
# /whoami bootstrap run; no privileged command works while it is empty.
ADMIN_USER_IDS=
DATABASE_PATH=./data/broadcaster.sqlite3
LOG_LEVEL=INFO
POLL_TIMEOUT_SECONDS=30
SEND_DELAY_SECONDS=0.2
DRAFT_TTL_MINUTES=15
